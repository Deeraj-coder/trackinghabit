rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Match any document in the 'habits' collection
    match /habits/{habitId} {
      // Allow read/write if the user is authenticated and the document's userId matches their uid
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Match any document in the 'habitLogs' collection
    match /habitLogs/{logId} {
      // A user can read/write logs if they own the associated habit.
      // We check this by getting the habit document and verifying its userId.
      function userOwnsHabit(habitId) {
        return get(/databases/$(database)/documents/habits/$(habitId)).data.userId == request.auth.uid;
      }
      
      allow create: if isAuthenticated() && userOwnsHabit(request.resource.data.habitId);
      allow read, update, delete: if isAuthenticated() && userOwnsHabit(resource.data.habitId);
    }
  }
}
